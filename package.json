{
  "name": "hoa-hoc-thcs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate-content && npm run typecheck && vite build",
    "generate:content-catalog": "tsx scripts/generate-content-catalog.ts",
    "check:content-catalog": "tsx scripts/generate-content-catalog.ts --check",
    "check:bundle": "tsx scripts/check-bundle-budget.ts",
    "check:licenses": "tsx scripts/check-licenses.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test tests/e2e",
    "test:pwa": "playwright test tests/e2e/pwa-offline.spec.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate-content": "tsx scripts/validate-content.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.57.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.4",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.0.15",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.4.21",
    "eslint": "9.32.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "postcss": "8.5.19",
    "prettier": "3.6.2",
    "tailwindcss": "3.4.17",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0",
    "vite": "6.4.3",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "3.2.7"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
